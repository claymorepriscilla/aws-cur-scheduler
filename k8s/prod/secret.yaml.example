# ============================================================
# k8s/prod/secret.yaml.example
# PROD ใช้ IRSA → AWS_ACCESS_KEY_ID / SECRET ไม่จำเป็น
# แต่ TEAMS_WEBHOOK_URL ยังต้องใส่ผ่าน Secret
# ⚠️  secret.yaml is listed in .gitignore — never commit real secrets
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: aws-cur-scheduler-secret
  namespace: cost-reporter-prod
  labels:
    app: aws-cur-scheduler
    env: prod
type: Opaque
stringData:
  TEAMS_WEBHOOK_URL: "REPLACE_ME"
  # AWS credentials NOT needed in prod — handled by IRSA

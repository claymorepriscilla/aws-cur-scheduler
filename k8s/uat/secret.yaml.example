# ============================================================
# k8s/uat/secret.yaml.example
# Copy to secret.yaml and fill in real values.
# ⚠️  secret.yaml is listed in .gitignore — never commit real secrets
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: aws-cur-scheduler-secret
  namespace: cost-reporter-uat
  labels:
    app: aws-cur-scheduler
    env: uat
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: "REPLACE_ME"
  AWS_SECRET_ACCESS_KEY: "REPLACE_ME"
  TEAMS_WEBHOOK_URL: "REPLACE_ME"

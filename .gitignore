# ============================================================
# .gitignore — aws-cur-scheduler
# ============================================================

# ── Go build artifacts ──────────────────────────────────────
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
aws-cur-scheduler

# Test artifacts
*.test
*.out
coverage.html
coverage.out
profile.out

# ── Config files with real secrets ─────────────────────────
# IMPORTANT: Never commit local.yaml — it contains real credentials
configs/local.yaml
configs/local.yaml.secret
configs/*.override.yaml
.env
.env.*
!.env.example
.env.local.example

# Note: keep `configs/*.example` in repo as templates. Do NOT commit real secrets.

# ── Go module cache / vendor ────────────────────────────────
vendor/

# ── IDE / Editor ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Docker ──────────────────────────────────────────────────
.docker/

# ── Kubernetes secrets (never commit real secrets) ──────────
k8s/**/secret.yaml
k8s/**/*-secret.yaml
!k8s/**/secret.yaml.example

# ── Temporary files ─────────────────────────────────────────
tmp/
temp/
*.tmp
